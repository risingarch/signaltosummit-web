---
/**
 * PageLayout — Full page layout with Nav + Footer
 * Wraps BaseLayout and slots in the navigation and footer.
 * Use this for all standard pages.
 */
import BaseLayout from './BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonicalURL?: string;
  pageType?: 'website' | 'article';
}

const props = Astro.props;
---

<BaseLayout {...props}>
  <Nav slot="header" />
  <slot />
  <Footer slot="footer" />
</BaseLayout>
