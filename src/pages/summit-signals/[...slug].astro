---
import PageLayout from '../../layouts/PageLayout.astro';
import ShareButtons from '../../components/ShareButtons.astro';
import MidReadSubscribe from '../../components/MidReadSubscribe.astro';
import KeepReading from '../../components/KeepReading.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const signals = await getCollection('signals', ({ data }) => !data.draft);
  return signals.map((signal) => ({
    params: { slug: signal.id },
    props: { signal },
  }));
}

const { signal } = Astro.props;
const { Content } = await render(signal);

// Get all signals for Keep Reading section
const allSignals = await getCollection('signals', ({ data }) => !data.draft);

// Estimate read time from content body
const wordCount = signal.body ? signal.body.split(/\s+/).length : 0;
const readMinutes = Math.max(3, Math.ceil(wordCount / 230));
const readTime = `${readMinutes} min read`;

// Build canonical URL
const canonicalUrl = `https://signaltosummit.com/summit-signals/${signal.id}`;

// Build OG image — thumbnail or YouTube thumb or default
const ogImage = signal.data.thumbnail
  || (signal.data.videoUrl
    ? `https://img.youtube.com/vi/${signal.data.videoUrl.split('/').pop()}/maxresdefault.jpg`
    : '/images/og-default.png');

// Executive summary for meta description (first 2 sentences)
const execSummaryMeta = signal.data.executiveSummary
  ? signal.data.executiveSummary.split('. ').slice(0, 2).join('. ') + '.'
  : signal.data.description;

// Formatted date
const publishDate = new Date(signal.data.publishDate).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// Schema.org structured data
const schemas: Record<string, unknown>[] = [
  {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: signal.data.title,
    description: execSummaryMeta,
    author: {
      '@type': 'Person',
      name: signal.data.author,
      jobTitle: 'Founder, Signal to Summit',
    },
    publisher: {
      '@type': 'Organization',
      name: 'Signal to Summit',
      logo: {
        '@type': 'ImageObject',
        url: 'https://signaltosummit.com/images/logo-horizontal.png',
      },
    },
    datePublished: new Date(signal.data.publishDate).toISOString(),
    image: ogImage,
    mainEntityOfPage: {
      '@type': 'WebPage',
      '@id': canonicalUrl,
    },
  },
];

if (signal.data.videoUrl) {
  schemas.push({
    '@context': 'https://schema.org',
    '@type': 'VideoObject',
    name: signal.data.videoTitle || signal.data.title,
    description: signal.data.description,
    thumbnailUrl: `https://img.youtube.com/vi/${signal.data.videoUrl.split('/').pop()}/maxresdefault.jpg`,
    uploadDate: new Date(signal.data.publishDate).toISOString(),
    embedUrl: signal.data.videoUrl,
    author: {
      '@type': 'Person',
      name: signal.data.author,
    },
  });
}

---

<PageLayout
  title={signal.data.title}
  description={execSummaryMeta}
  ogImage={ogImage}
  canonicalURL={canonicalUrl}
  pageType="article"
  schema={schemas}
>
  <article>
    {/* -- Breadcrumb -- */}
    <div class="mx-auto w-full max-w-[45rem] px-6 pt-8">
      <nav class="text-xs text-summit-navy/50" aria-label="Breadcrumb">
        <ol class="flex items-center gap-1.5">
          <li><a href="/" class="hover:text-signal-blue-dark transition-colors">Home</a></li>
          <li aria-hidden="true">&rsaquo;</li>
          <li><a href="/summit-signals" class="hover:text-signal-blue-dark transition-colors">Summit Signals</a></li>
          <li aria-hidden="true">&rsaquo;</li>
          <li class="text-summit-navy/70 truncate max-w-[200px]" aria-current="page">{signal.data.title}</li>
        </ol>
      </nav>
    </div>

    {/* -- Article Header -- */}
    <section class="pt-8 pb-8 md:pt-12 md:pb-12">
      <div class="mx-auto w-full max-w-[45rem] px-6">
        {/* Title (H1) */}
        <h1 class="text-summit-navy mb-4">{signal.data.title}</h1>

        {/* Subtitle/teaser */}
        <p class="text-summit-navy/70 text-lg leading-relaxed mb-4">
          {signal.data.teaser || signal.data.description}
        </p>

        {/* Meta line */}
        <p class="text-summit-navy/50 text-sm mb-6">
          {signal.data.author} &middot; {publishDate} &middot; {readTime}
        </p>

        {/* Share buttons — top placement */}
        <ShareButtons
          title={signal.data.title}
          url={canonicalUrl}
          description={execSummaryMeta}
        />
      </div>
    </section>

    {/* -- Header Image (if thumbnail set, renders as hero art at top) -- */}
    {signal.data.thumbnail && (
      <section class="pb-8 md:pb-12">
        <div class="mx-auto w-full max-w-[45rem] px-6">
          <div class="rounded-lg overflow-hidden">
            <img
              src={signal.data.thumbnail}
              alt={`${signal.data.title} header art`}
              class="w-full h-auto"
              loading="eager"
            />
          </div>
        </div>
      </section>
    )}

    {/* -- Executive Summary -- */}
    {signal.data.executiveSummary && (
      <section class="pb-8 md:pb-12">
        <div class="mx-auto w-full max-w-[45rem] px-6">
          <div class="border-l-[3px] border-signal-blue/30 bg-soft-gray/60 rounded-r-lg pl-6 pr-6 py-5">
            <p class="text-summit-navy/90 text-xs font-semibold uppercase tracking-wider mb-3">Executive Summary</p>
            <p class="text-summit-navy/80 text-base leading-relaxed">
              {signal.data.executiveSummary}
            </p>
          </div>
        </div>
      </section>
    )}

    {/* -- Video (if present) -- */}
    {signal.data.videoUrl && (
      <section class="pb-8 md:pb-12">
        <div class="mx-auto w-full max-w-[45rem] px-6">
          <div class="aspect-video rounded-lg overflow-hidden mb-4">
            <iframe
              src={`${signal.data.videoUrl}?rel=0&modestbranding=1`}
              title={signal.data.videoTitle || signal.data.title}
              class="w-full h-full"
              loading="lazy"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
            ></iframe>
          </div>
          {signal.data.videoDuration && (
            <p class="text-summit-navy/60 text-sm">
              Watch the full thesis ({signal.data.videoDuration}) or read the written version below.
            </p>
          )}
        </div>
      </section>
    )}

    {/* -- Collapsible Transcript -- */}
    {signal.data.transcript && (
      <section class="pb-8">
        <div class="mx-auto w-full max-w-[45rem] px-6">
          <details class="border border-soft-gray rounded-lg">
            <summary class="px-6 py-4 cursor-pointer text-summit-navy/70 text-sm font-medium hover:text-summit-navy transition-colors">
              View video transcript
            </summary>
            <div class="px-6 pb-6 pt-2 text-summit-navy/70 text-sm leading-relaxed whitespace-pre-line border-t border-soft-gray">
              {signal.data.transcript}
            </div>
          </details>
        </div>
      </section>
    )}

    {/* -- Article Body -- */}
    <section class="pb-12 md:pb-16">
      <div class="mx-auto w-full max-w-[45rem] px-6 prose-thesis">
        <Content />
      </div>
    </section>

    {/* -- Mid-Read Subscribe Prompt (positioned via scroll JS) -- */}
    <MidReadSubscribe />

    {/* -- Share Buttons — bottom placement -- */}
    <section class="py-8">
      <div class="mx-auto w-full max-w-[45rem] px-6">
        <ShareButtons
          title={signal.data.title}
          url={canonicalUrl}
          description={execSummaryMeta}
        />
      </div>
    </section>

    {/* -- Comments Section — placeholder with recommendation -- */}
    <section class="py-8 border-t border-summit-navy/10" id="discussion">
      <div class="mx-auto w-full max-w-[45rem] px-6">
        <h2 class="text-summit-navy text-xl font-bold mb-4">Discussion</h2>
        <div class="bg-soft-gray rounded-lg p-6 text-center">
          <p class="text-summit-navy/60 text-sm mb-3">
            Comments are coming soon. Subscribe to get notified when the discussion opens.
          </p>
          <form class="flex gap-3 max-w-sm mx-auto" id="comments-email-form">
            <label for="comments-email" class="sr-only">Email address</label>
            <input
              type="email"
              id="comments-email"
              name="email"
              placeholder="you@company.com"
              required
              class="flex-1 border border-summit-navy/20 rounded-lg px-4 py-2.5 text-sm text-summit-navy bg-white placeholder:text-summit-navy/30 focus:outline-none focus:ring-2 focus:ring-signal-blue focus:border-transparent"
            />
            <button
              type="submit"
              class="bg-signal-blue-btn text-white text-sm font-medium px-5 py-2.5 rounded-lg hover:bg-signal-blue-dark transition-colors flex-shrink-0"
            >
              Subscribe
            </button>
          </form>
        </div>
      </div>
    </section>

    {/* -- Keep Reading -- */}
    <KeepReading signals={allSignals} currentSlug={signal.id} />
  </article>
</PageLayout>
