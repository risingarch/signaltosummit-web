---
import PageLayout from '../../layouts/PageLayout.astro';
import { getCollection } from 'astro:content';

// Get all published signals, sorted newest first
const allSignals = await getCollection('signals', ({ data }) => !data.draft);
const signals = allSignals.sort((a, b) =>
  new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime()
);

// Calculate estimated read time from content length
function estimateReadTime(description: string): string {
  // Rough estimate based on description + typical article length
  // Will be more accurate when we can access rendered content
  const words = description.split(/\s+/).length;
  const minutes = Math.max(3, Math.ceil(words / 200) + 5);
  return `${minutes} min read`;
}
---

<PageLayout
  title="Summit Signals"
  description="The patterns shaping retail media — before they show up in your pipeline. Analysis from Signal to Summit."
>
  {/* -- Hero Area -- */}
  <section class="pt-20 md:pt-28 pb-12 md:pb-16">
    <div class="mx-auto w-full max-w-[45rem] px-6">
      <h1 class="text-summit-navy mb-4">Summit Signals</h1>
      <p class="text-summit-navy/80 text-lg md:text-xl leading-relaxed mb-3">
        The patterns shaping retail media — before they show up in your pipeline.
      </p>
      <p class="text-summit-navy/60 text-base leading-relaxed mb-8">
        How retail media actually operates — from someone who spent seven years building it from the inside. One signal at a time.
      </p>

      {/* Subscribe field — below copy, earns the email */}
      <p class="text-summit-navy/70 text-sm mb-3">Get each new signal delivered to your inbox.</p>
      <form class="flex gap-3 max-w-md" id="hub-email-form">
        <label for="hub-email" class="sr-only">Email address</label>
        <input
          type="email"
          id="hub-email"
          name="email"
          placeholder="you@company.com"
          required
          class="flex-1 border border-summit-navy/20 rounded-lg px-4 py-3 text-summit-navy bg-white placeholder:text-summit-navy/30 focus:outline-none focus:ring-2 focus:ring-signal-blue focus:border-transparent"
        />
        <button
          type="submit"
          class="bg-signal-blue-btn text-white text-sm font-medium px-6 py-3 rounded-lg hover:bg-signal-blue-dark transition-colors flex-shrink-0"
        >
          Subscribe
        </button>
      </form>
    </div>
  </section>

  {/* -- Content Feed — chronological, no category tabs -- */}
  <section class="pb-16 md:pb-24">
    <div class="mx-auto w-full max-w-[45rem] px-6">
      {signals.length > 0 ? (
        <div id="content-feed">
          {signals.map((signal, index) => (
            <a
              href={`/summit-signals/${signal.id}`}
              class="group block py-6 first:pt-0"
            >
              <article class="flex gap-6 items-start">
                {/* Text content */}
                <div class="flex-1 min-w-0">
                  {/* Date + read time */}
                  <p class="text-summit-navy/50 text-xs mb-2">
                    {new Date(signal.data.publishDate).toLocaleDateString('en-US', {
                      year: 'numeric',
                      month: 'long',
                      day: 'numeric',
                    })}
                    {' '}&middot;{' '}
                    {signal.data.videoDuration
                      ? `${signal.data.videoDuration} video`
                      : estimateReadTime(signal.data.description)}
                  </p>

                  {/* Title */}
                  <h2 class="text-summit-navy font-bold text-lg md:text-xl leading-snug mb-2 group-hover:text-signal-blue-dark transition-colors">
                    {signal.data.title}
                  </h2>

                  {/* One-line teaser */}
                  <p class="text-summit-navy/60 text-sm leading-relaxed">
                    {signal.data.teaser || signal.data.description.slice(0, 120)}
                  </p>
                </div>

                {/* Thumbnail (right-aligned) */}
                {signal.data.thumbnail ? (
                  <div class="hidden sm:block flex-shrink-0 w-32 h-20 md:w-40 md:h-24 rounded-lg overflow-hidden bg-soft-gray relative">
                    <img
                      src={signal.data.thumbnail}
                      alt=""
                      class="w-full h-full object-cover"
                      loading="lazy"
                    />
                    {signal.data.videoUrl && (
                      <div class="absolute inset-0 flex items-center justify-center">
                        <div class="w-8 h-8 bg-summit-navy/70 rounded-full flex items-center justify-center">
                          <svg class="w-3 h-3 text-white ml-0.5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M8 5v14l11-7z"/>
                          </svg>
                        </div>
                      </div>
                    )}
                  </div>
                ) : signal.data.videoUrl ? (
                  <div class="hidden sm:block flex-shrink-0 w-32 h-20 md:w-40 md:h-24 rounded-lg overflow-hidden bg-soft-gray relative">
                    <img
                      src={`https://img.youtube.com/vi/${signal.data.videoUrl.split('/').pop()}/mqdefault.jpg`}
                      alt=""
                      class="w-full h-full object-cover"
                      loading="lazy"
                    />
                    <div class="absolute inset-0 flex items-center justify-center">
                      <div class="w-8 h-8 bg-summit-navy/70 rounded-full flex items-center justify-center">
                        <svg class="w-3 h-3 text-white ml-0.5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                          <path d="M8 5v14l11-7z"/>
                        </svg>
                      </div>
                    </div>
                  </div>
                ) : null}
              </article>
              {/* Divider between entries */}
              {index < signals.length - 1 && (
                <div class="border-b border-summit-navy/8 mt-6" />
              )}
            </a>
          ))}
        </div>
      ) : (
        <div class="text-center py-12">
          <p class="text-summit-navy/50 text-lg mb-2">Content is on the way.</p>
          <p class="text-summit-navy/50 text-sm">
            Subscribe above to be notified when new signals drop.
          </p>
        </div>
      )}
    </div>
  </section>
</PageLayout>
