---
import PageLayout from '../layouts/PageLayout.astro';

const contactSchema = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  mainEntity: {
    '@type': 'Organization',
    name: 'Signal to Summit',
    email: 'jaiah@signaltosummit.com',
    url: 'https://signaltosummit.com',
  },
};
---

<PageLayout
  title="Contact"
  description="Tell Signal to Summit what you're navigating. If there's a fit, we'll find time for a conversation."
  schema={contactSchema}
>
  {/* ── Section 6.1: OPENING FRAME ── */}
  <section class="py-20 md:py-28">
    <div class="mx-auto w-full max-w-[45rem] px-6">
      <h1 class="text-summit-navy mb-4">
        Let's see if there's a fit.
      </h1>
      <p class="text-summit-navy/70 text-base md:text-lg leading-relaxed mb-12">
        Tell me what you're navigating. If Signal to Summit is the right resource, we'll find time for a conversation.
      </p>

      {/* ── Section 6.2: CONTACT FORM ── */}
      <form id="contact-form" class="space-y-6" novalidate>
        {/* Honeypot — invisible to humans, bots fill it */}
        <div class="absolute -left-[9999px]" aria-hidden="true">
          <label for="website">Website</label>
          <input type="text" id="website" name="website" tabindex="-1" autocomplete="off" />
        </div>

        <div>
          <label for="name" class="block text-summit-navy font-medium text-sm mb-2">Name</label>
          <input
            type="text"
            id="name"
            name="name"
            required
            class="w-full border border-summit-navy/20 rounded-lg px-4 py-3 text-summit-navy bg-white placeholder:text-summit-navy/30 focus:outline-none focus:ring-2 focus:ring-signal-blue focus:border-transparent transition-colors"
            placeholder="Your name"
          />
        </div>

        <div>
          <label for="email" class="block text-summit-navy font-medium text-sm mb-2">Email</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            class="w-full border border-summit-navy/20 rounded-lg px-4 py-3 text-summit-navy bg-white placeholder:text-summit-navy/30 focus:outline-none focus:ring-2 focus:ring-signal-blue focus:border-transparent transition-colors"
            placeholder="you@company.com"
          />
        </div>

        <div>
          <label for="company" class="block text-summit-navy font-medium text-sm mb-2">Company</label>
          <input
            type="text"
            id="company"
            name="company"
            class="w-full border border-summit-navy/20 rounded-lg px-4 py-3 text-summit-navy bg-white placeholder:text-summit-navy/30 focus:outline-none focus:ring-2 focus:ring-signal-blue focus:border-transparent transition-colors"
            placeholder="Your company"
          />
        </div>

        <div>
          <label for="role" class="block text-summit-navy font-medium text-sm mb-2">Your Role</label>
          <input
            type="text"
            id="role"
            name="role"
            class="w-full border border-summit-navy/20 rounded-lg px-4 py-3 text-summit-navy bg-white placeholder:text-summit-navy/30 focus:outline-none focus:ring-2 focus:ring-signal-blue focus:border-transparent transition-colors"
            placeholder="Your title or role"
          />
        </div>

        <div>
          <label for="message" class="block text-summit-navy font-medium text-sm mb-2">What are you navigating right now?</label>
          <textarea
            id="message"
            name="message"
            rows="4"
            class="w-full border border-summit-navy/20 rounded-lg px-4 py-3 text-summit-navy bg-white placeholder:text-summit-navy/30 focus:outline-none focus:ring-2 focus:ring-signal-blue focus:border-transparent transition-colors resize-y"
            placeholder="Tell me about the challenges you're facing..."
          ></textarea>
        </div>

        <div>
          <button
            type="submit"
            class="bg-signal-blue text-white font-medium px-8 py-4 rounded-lg hover:bg-signal-blue/90 transition-colors focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-signal-blue w-full md:w-auto"
          >
            Start the conversation
          </button>
        </div>

        {/* Error message area */}
        <div id="form-error" class="hidden text-red-600 text-sm" role="alert"></div>
      </form>

      {/* ── Section 6.3: CONFIRMATION ── */}
      <div id="form-confirmation" class="hidden py-12 text-center">
        <div class="bg-ice-blue rounded-lg p-8">
          <svg class="w-12 h-12 mx-auto text-signal-blue mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <p class="text-summit-navy text-lg leading-relaxed" id="confirmation-message">
            Thanks. I'll review what you've shared and follow up within two business days.
          </p>
        </div>
      </div>
    </div>
  </section>
</PageLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const confirmation = document.getElementById('form-confirmation');
  const errorDiv = document.getElementById('form-error');
  const confirmationMessage = document.getElementById('confirmation-message');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Check honeypot
    const honeypot = form.querySelector<HTMLInputElement>('input[name="website"]');
    if (honeypot?.value) {
      // Bot detected — show fake success
      form.classList.add('hidden');
      confirmation?.classList.remove('hidden');
      return;
    }

    const submitBtn = form.querySelector<HTMLButtonElement>('button[type="submit"]');
    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.textContent = 'Sending...';
    }

    // Hide any previous errors
    errorDiv?.classList.add('hidden');

    const formData = new FormData(form);
    const data = {
      name: formData.get('name'),
      email: formData.get('email'),
      company: formData.get('company'),
      role: formData.get('role'),
      message: formData.get('message'),
    };

    try {
      const response = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      if (response.ok) {
        const name = (data.name as string)?.split(' ')[0] || '';
        if (confirmationMessage) {
          confirmationMessage.textContent = `Thanks, ${name}. I'll review what you've shared and follow up within two business days.`;
        }
        form.classList.add('hidden');
        confirmation?.classList.remove('hidden');
      } else {
        throw new Error('Submission failed');
      }
    } catch {
      if (errorDiv) {
        errorDiv.textContent = 'Something went wrong. Please try again or email directly.';
        errorDiv.classList.remove('hidden');
      }
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Start the conversation';
      }
    }
  });
</script>
