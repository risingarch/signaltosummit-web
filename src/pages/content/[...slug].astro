---
import PageLayout from '../../layouts/PageLayout.astro';
import BottomCTA from '../../components/BottomCTA.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const signals = await getCollection('signals', ({ data }) => !data.draft);
  return signals.map((signal) => ({
    params: { slug: signal.id },
    props: { signal },
  }));
}

const { signal } = Astro.props;
const { Content } = await render(signal);

const pillarLabels: Record<string, string> = {
  thesis: 'Thesis',
  'pattern-recognition': 'Pattern Recognition',
  'buyer-education': 'Buyer Education',
};

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: signal.data.title,
  description: signal.data.description,
  author: {
    '@type': 'Person',
    name: signal.data.author,
  },
  publisher: {
    '@type': 'Organization',
    name: 'Signal to Summit',
    logo: {
      '@type': 'ImageObject',
      url: 'https://signaltosummit.com/images/logo-horizontal.png',
    },
  },
  datePublished: new Date(signal.data.publishDate).toISOString(),
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': `https://signaltosummit.com/content/${signal.id}`,
  },
  articleSection: pillarLabels[signal.data.pillar] || signal.data.pillar,
};
---

<PageLayout
  title={signal.data.title}
  description={signal.data.description}
  pageType="article"
  schema={articleSchema}
>
  <article>
    {/* Header */}
    <section class="py-20 md:py-28">
      <div class="mx-auto w-full max-w-[45rem] px-6">
        <span class="inline-block text-xs font-medium text-signal-blue-dark mb-4 uppercase tracking-wider">
          {pillarLabels[signal.data.pillar] || signal.data.pillar}
        </span>
        <h1 class="text-summit-navy mb-4">{signal.data.title}</h1>
        <p class="text-summit-navy/70 text-base md:text-lg leading-relaxed mb-4">
          {signal.data.description}
        </p>
        <p class="text-summit-navy/50 text-sm">
          By {signal.data.author} &middot;{' '}
          {new Date(signal.data.publishDate).toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          })}
        </p>
      </div>
    </section>

    {/* Video (if present) */}
    {signal.data.videoUrl && (
      <section class="pb-16 md:pb-24">
        <div class="mx-auto w-full max-w-[45rem] px-6">
          <div class="aspect-video rounded-lg overflow-hidden">
            <iframe
              src={`${signal.data.videoUrl}?rel=0&modestbranding=1`}
              title={signal.data.videoTitle || signal.data.title}
              class="w-full h-full"
              loading="lazy"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
            ></iframe>
          </div>
        </div>
      </section>
    )}

    {/* Written content */}
    <section class="pb-16 md:pb-24">
      <div class="mx-auto w-full max-w-[45rem] px-6 prose prose-lg prose-summit-navy">
        <Content />
      </div>
    </section>

    {/* Email signup */}
    <section class="bg-soft-gray py-12">
      <div class="mx-auto w-full max-w-[45rem] px-6 text-center">
        <p class="text-summit-navy/70 text-sm mb-4">Get notified when new analysis drops.</p>
        <form class="flex gap-3 max-w-md mx-auto">
          <label for="content-email" class="sr-only">Email address</label>
          <input
            type="email"
            id="content-email"
            name="email"
            placeholder="you@company.com"
            required
            class="flex-1 border border-summit-navy/20 rounded-lg px-4 py-3 text-sm text-summit-navy bg-white placeholder:text-summit-navy/30 focus:outline-none focus:ring-2 focus:ring-signal-blue focus:border-transparent"
          />
          <button
            type="submit"
            class="bg-signal-blue-btn text-white text-sm font-medium px-5 py-3 rounded-lg hover:bg-signal-blue-dark transition-colors flex-shrink-0"
          >
            Subscribe
          </button>
        </form>
      </div>
    </section>
  </article>

  {/* CTA */}
  <BottomCTA heading="If this resonated, let's talk about what it looks like in your world." />
</PageLayout>
