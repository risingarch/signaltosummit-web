---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout
  title="Signal to Summit"
  description="Strategic advisory for platform leaders whose retail media deals keep stalling — not because the technology fails, but because the approach doesn't account for how retailers actually operate."
>
  <section class="bg-summit-navy py-24 md:py-32">
    <div class="mx-auto w-full max-w-[45rem] px-6">
      <h1 class="text-white text-3xl md:text-4xl font-bold leading-tight mb-6">
        Your product isn't the problem. The way it meets the retailer's operating reality is.
      </h1>
      <p class="text-white/80 text-lg md:text-xl leading-relaxed mb-8 max-w-2xl">
        Strategic advisory for platform leaders whose retail media deals keep stalling — not because the technology fails, but because the approach doesn't account for how retailers actually operate.
      </p>
      <a
        href="/contact"
        class="inline-block bg-signal-blue text-white font-medium px-8 py-4 rounded-lg hover:bg-signal-blue/90 transition-colors"
      >
        Let's Talk
      </a>
    </div>
  </section>
</PageLayout>
