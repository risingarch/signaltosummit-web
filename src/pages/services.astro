---
import PageLayout from '../layouts/PageLayout.astro';
import Section from '../components/Section.astro';
import BottomCTA from '../components/BottomCTA.astro';

const servicesSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  provider: {
    '@type': 'Organization',
    name: 'Signal to Summit',
  },
  serviceType: 'Strategic Advisory',
  description: 'Four ways to work together. Each built around a decision you\'re trying to make.',
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Advisory Services',
    itemListElement: [
      {
        '@type': 'OfferCatalog',
        name: 'Executive Briefing',
        description: 'A session on the patterns that stall retail media deals. Single session. No ongoing commitment required.',
      },
      {
        '@type': 'OfferCatalog',
        name: 'Strategy Review',
        description: 'A focused diagnosis of your retail media strategy, go-to-market execution, or implementation. Scoped after an initial conversation.',
      },
      {
        '@type': 'OfferCatalog',
        name: 'Readiness Assessment',
        description: 'A two-part diagnostic evaluating data quality, process maturity, organizational alignment, and systems integration. Maps what is impacting adoption inside your retailer customers.',
      },
      {
        '@type': 'OfferCatalog',
        name: 'Strategic Advisory',
        description: 'Ongoing access to operator-level judgment. Scheduled strategic sessions combined with on-demand advisory.',
      },
    ],
  },
};
---

<PageLayout
  title="Services"
  description="Four ways to work with Signal to Summit. Each built around a decision you're trying to make. Executive Briefing, Strategy Review, Readiness Assessment, Strategic Advisory."
  schema={servicesSchema}
>
  {/* ── Section 3.1: OPENING FRAME ── */}
  <section class="py-20 md:py-28">
    <div class="mx-auto w-full max-w-[45rem] px-6">
      <h1 class="text-summit-navy mb-4">
        Four ways to work together. Each built around a decision you're trying to make.
      </h1>
      <p class="text-summit-navy/70 text-base md:text-lg leading-relaxed">
        Every engagement is scoped to your situation.
      </p>
    </div>
  </section>

  {/* ── Section Break: Sherpa Image ── */}
  <section class="bg-white px-4 md:px-6">
    <div class="mx-auto max-w-7xl">
      <img
        src="/images/sherpa-rope-bridge.jpg"
        alt="Sherpa leading across a rope bridge — navigating complexity with experience"
        class="w-full h-auto max-h-[28rem] object-cover object-[center_40%]"
        loading="lazy"
        width="1200"
        height="675"
      />
    </div>
  </section>

  {/* ── Section 3.2: PRODUCT CARDS ── */}

  {/* Product 1: Executive Briefing */}
  <Section background="soft-gray">
    <div class="w-12 h-0.5 bg-signal-blue mb-8"></div>
    <div class="mb-4">
      <span class="inline-block bg-signal-blue/10 text-signal-blue-dark text-xs font-medium px-3 py-1 rounded-full">
        Most clients start here
      </span>
    </div>
    <h2 class="text-summit-navy mb-4">Executive Briefing</h2>
    <p class="text-summit-navy/80 italic text-base md:text-lg mb-6">
      "What am I missing about how retail media actually operates?"
    </p>
    <p class="text-summit-navy/90 leading-relaxed mb-8">
      A session on the patterns that stall retail media deals — built from ten years inside a top-10 retailer, with seven of those years building retail media. Tailored to your specific market position and your customers. Designed for your leadership team.
    </p>

    <div class="mb-8">
      <h3 class="text-summit-navy font-medium mb-3">What You Walk Away With</h3>
      <p class="text-summit-navy/80 leading-relaxed">
        A clear read on the operating dynamics affecting your partnerships, a one-page summary of key patterns identified, and — if there's a fit — a recommendation for what to look at next.
      </p>
    </div>

    <div class="mb-8">
      <h3 class="text-summit-navy font-medium mb-3">Engagement Model</h3>
      <p class="text-summit-navy/80 leading-relaxed">
        Single session. No ongoing commitment required.
      </p>
    </div>

    <a
      href="/contact"
      class="inline-block bg-signal-blue-btn text-white font-medium px-8 py-4 rounded-lg hover:bg-signal-blue-dark transition-colors"
    >
      Start here
    </a>
  </Section>

  {/* Product 2: Strategy Review */}
  <Section>
    <div class="w-12 h-0.5 bg-signal-blue mb-8"></div>
    <h2 class="text-summit-navy mb-4">Strategy Review</h2>
    <p class="text-summit-navy/80 italic text-base md:text-lg mb-6">
      "Are we reading the situation correctly?"
    </p>
    <p class="text-summit-navy/90 leading-relaxed mb-8">
      A focused diagnosis of your retail media strategy, go-to-market execution, or implementation — from ten years inside a top-10 retailer, with seven building retail media. A specific read on what's creating friction in your deals, your renewals, or your customer adoption.
    </p>

    <div class="mb-8">
      <h3 class="text-summit-navy font-medium mb-3">What You Walk Away With</h3>
      <p class="text-summit-navy/80 leading-relaxed">
        A written assessment with findings, pattern analysis, and specific recommendations. Plus a working session to walk through the analysis and align on next steps.
      </p>
    </div>

    <div class="mb-8">
      <h3 class="text-summit-navy font-medium mb-3">Engagement Model</h3>
      <p class="text-summit-navy/80 leading-relaxed">
        Scoped after an initial conversation.
      </p>
    </div>

    <a
      href="/contact"
      class="inline-block bg-signal-blue-btn text-white font-medium px-8 py-4 rounded-lg hover:bg-signal-blue-dark transition-colors"
    >
      Let's scope it
    </a>
  </Section>

  {/* Product 3: Readiness Assessment */}
  <Section background="soft-gray">
    <div class="w-12 h-0.5 bg-signal-blue mb-8"></div>
    <h2 class="text-summit-navy mb-4">Readiness Assessment</h2>
    <p class="text-summit-navy/80 italic text-base md:text-lg mb-6">
      "Where is the friction in our implementation?"
    </p>
    <p class="text-summit-navy/90 leading-relaxed mb-8">
      A two-part diagnostic. First: an onboarding engagement that builds a readiness rubric for your platform — evaluating data quality, process maturity, organizational alignment, and systems integration. Second: a per-deal audit applied before or during implementation to map what's impacting adoption inside your retailer customers.
    </p>

    <div class="mb-8">
      <h3 class="text-summit-navy font-medium mb-3">What You Walk Away With</h3>
      <p class="text-summit-navy/80 leading-relaxed">
        A readiness rubric tailored to your platform. For each audit: a structured roadmap so you can fix the process, not just the product.
      </p>
    </div>

    <div class="mb-8">
      <h3 class="text-summit-navy font-medium mb-3">Engagement Model</h3>
      <p class="text-summit-navy/80 leading-relaxed">
        Scoped per engagement. Can be delivered directly or embedded into your customer implementation process.
      </p>
    </div>

    <a
      href="/contact"
      class="inline-block bg-signal-blue-btn text-white font-medium px-8 py-4 rounded-lg hover:bg-signal-blue-dark transition-colors"
    >
      Explore readiness
    </a>
  </Section>

  {/* Product 4: Strategic Advisory */}
  <Section>
    <div class="w-12 h-0.5 bg-signal-blue mb-8"></div>
    <h2 class="text-summit-navy mb-4">Strategic Advisory</h2>
    <p class="text-summit-navy/80 italic text-base md:text-lg mb-6">
      "Do I have the right thinking partner for what's ahead?"
    </p>
    <p class="text-summit-navy/90 leading-relaxed mb-8">
      Ongoing access to operator-level judgment through scheduled sessions and on-demand advisory. For the decisions that don't wait for the next meeting.
    </p>

    <div class="mb-8">
      <h3 class="text-summit-navy font-medium mb-3">What You Walk Away With</h3>
      <p class="text-summit-navy/80 leading-relaxed">
        Monthly or biweekly strategic sessions, plus access between sessions when a situation requires real-time judgment.
      </p>
    </div>

    <div class="mb-8">
      <h3 class="text-summit-navy font-medium mb-3">Engagement Model</h3>
      <p class="text-summit-navy/80 leading-relaxed">
        3, 6, or 9-month commitment. Limited to a small number of concurrent clients.
      </p>
    </div>

    <a
      href="/contact"
      class="inline-block bg-signal-blue-btn text-white font-medium px-8 py-4 rounded-lg hover:bg-signal-blue-dark transition-colors"
    >
      Let's discuss fit
    </a>
  </Section>

  {/* ── Section 3.3: BOTTOM FRAME ── */}
  <section class="bg-summit-navy py-16 md:py-24">
    <div class="mx-auto w-full max-w-[45rem] px-6 text-center">
      <p class="text-white/80 text-lg leading-relaxed mb-8">
        Not sure where to start? That's what the first conversation is for.
      </p>
      <a
        href="/contact"
        class="inline-block bg-signal-blue-btn text-white font-medium px-8 py-4 rounded-lg hover:bg-signal-blue-dark transition-colors focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white"
      >
        Let's Talk
      </a>
    </div>
  </section>
</PageLayout>
