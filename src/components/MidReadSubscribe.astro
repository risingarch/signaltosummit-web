---
/**
 * MidReadSubscribe — Inline subscribe banner for articles
 * Appears at ~50-60% scroll depth, once per session, dismissable.
 * NOT a modal. Inline banner that flows with the content.
 * Brief Section 4B.
 */
---

<div
  id="mid-read-subscribe"
  class="hidden my-12 mx-auto w-full max-w-[45rem] px-6"
  role="complementary"
  aria-label="Subscribe to Summit Signals"
>
  <div class="relative bg-ice-blue rounded-lg px-6 py-8 md:px-8 md:py-10">
    <button
      id="mid-read-dismiss"
      class="absolute top-3 right-3 text-summit-navy/40 hover:text-summit-navy/70 transition-colors p-1"
      aria-label="Dismiss subscribe prompt"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
    <p class="text-summit-navy font-medium text-base md:text-lg mb-4 pr-6">
      Get operator-level analysis like this delivered to your inbox.
    </p>
    <form class="flex gap-3 max-w-md" id="mid-read-email-form">
      <label for="mid-read-email" class="sr-only">Email address</label>
      <input
        type="email"
        id="mid-read-email"
        name="email"
        placeholder="you@company.com"
        required
        class="flex-1 border border-summit-navy/20 rounded-lg px-4 py-3 text-sm text-summit-navy bg-white placeholder:text-summit-navy/30 focus:outline-none focus:ring-2 focus:ring-signal-blue focus:border-transparent"
      />
      <button
        type="submit"
        class="bg-signal-blue-btn text-white text-sm font-medium px-6 py-3 rounded-lg hover:bg-signal-blue-dark transition-colors flex-shrink-0"
      >
        Subscribe
      </button>
    </form>
  </div>
</div>

<script>
  const banner = document.getElementById('mid-read-subscribe');
  const dismissBtn = document.getElementById('mid-read-dismiss');
  const STORAGE_KEY = 'ss-mid-read-dismissed';

  // Don't show if already dismissed this session
  if (banner && !sessionStorage.getItem(STORAGE_KEY)) {
    let shown = false;

    const observer = new IntersectionObserver(() => {
      // We use scroll percentage instead
    });

    function checkScroll() {
      if (shown) return;

      const scrollTop = window.scrollY;
      const docHeight = document.documentElement.scrollHeight - window.innerHeight;
      const scrollPercent = (scrollTop / docHeight) * 100;

      if (scrollPercent >= 50 && scrollPercent <= 80) {
        shown = true;
        banner.classList.remove('hidden');
        banner.style.animation = 'fadeSlideIn 0.4s ease-out';
        window.removeEventListener('scroll', checkScroll);
      }
    }

    window.addEventListener('scroll', checkScroll, { passive: true });

    dismissBtn?.addEventListener('click', () => {
      banner.style.animation = 'fadeSlideOut 0.3s ease-in forwards';
      sessionStorage.setItem(STORAGE_KEY, '1');
      setTimeout(() => {
        banner.classList.add('hidden');
      }, 300);
    });
  }
</script>

<style>
  @keyframes fadeSlideIn {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fadeSlideOut {
    from {
      opacity: 1;
      transform: translateY(0);
    }
    to {
      opacity: 0;
      transform: translateY(12px);
    }
  }
</style>
