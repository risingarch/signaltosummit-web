---
/**
 * Footer — Global footer on all pages
 * Layered: Navigation first, then brand+subscribe, then legal
 * Summit Navy background
 */
const currentYear = new Date().getFullYear();
---

<footer class="bg-summit-navy text-white/80 border-t border-white/10">
  <div class="px-4 md:px-6 pt-16 md:pt-20 pb-12 md:pb-16">

    <!-- Row 1: Navigation — first thing readers see -->
    <nav class="flex flex-wrap items-center gap-x-8 gap-y-3 pb-10" aria-label="Footer navigation">
      <a href="/" class="text-sm text-white/60 hover:text-white transition-colors">Home</a>
      <a href="/services" class="text-sm text-white/60 hover:text-white transition-colors">Services</a>
      <a href="/summit-signals" class="text-sm text-white/60 hover:text-white transition-colors">Summit Signals</a>
      <a href="/about" class="text-sm text-white/60 hover:text-white transition-colors">About</a>
      <a href="/contact" class="text-sm text-white/60 hover:text-white transition-colors">Contact</a>
      <a href="/contact" class="text-sm text-signal-blue hover:text-white transition-colors font-medium">Let's Talk</a>
    </nav>

    <!-- Row 2: Brand + Subscribe -->
    <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-10 pt-10 border-t border-white/10">
      <!-- Brand -->
      <div>
        <a href="/" aria-label="Signal to Summit — Home">
          <img
            src="/images/logo-horizontal.png"
            alt="Signal to Summit"
            class="h-8 w-auto mb-4 brightness-0 invert"
            width="200"
            height="32"
          />
        </a>
        <p class="text-sm text-white/60 leading-relaxed max-w-xs">
          Strategic advisory for retail media platform leaders.
        </p>
      </div>

      <!-- Subscribe -->
      <div class="md:max-w-sm w-full">
        <p class="text-white font-semibold text-sm mb-2 tracking-wide uppercase">Stay informed</p>
        <p class="text-sm text-white/60 mb-3">Get notified when new analysis drops.</p>
        <form class="flex gap-2" id="footer-email-form">
          <label for="footer-email" class="sr-only">Email address</label>
          <input
            type="email"
            id="footer-email"
            name="email"
            placeholder="you@company.com"
            required
            class="flex-1 bg-white/10 border border-white/20 rounded-lg px-4 py-2.5 text-sm text-white placeholder:text-white/40 focus:outline-none focus:ring-2 focus:ring-signal-blue"
          />
          <button
            type="submit"
            class="bg-signal-blue-btn text-white text-sm font-medium px-5 py-2.5 rounded-lg hover:bg-signal-blue-dark transition-colors flex-shrink-0"
          >
            Subscribe
          </button>
        </form>
      </div>
    </div>

    <!-- Row 3: Copyright + Legal -->
    <div class="mt-10 pt-8 border-t border-white/10 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-xs text-white/60">
        &copy; {currentYear} Signal to Summit LLC. All rights reserved.
      </p>
      <div class="flex gap-6">
        <a href="/privacy" class="text-xs text-white/60 hover:text-white transition-colors">
          Privacy Policy
        </a>
        <a href="/privacy#sms-terms" class="text-xs text-white/60 hover:text-white transition-colors">
          SMS Terms & Conditions
        </a>
      </div>
    </div>
  </div>
</footer>
