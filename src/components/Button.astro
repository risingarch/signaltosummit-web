---
/**
 * Button — Signal Blue primary button
 * 16px vertical, 32px horizontal padding, 8px border radius
 */
interface Props {
  href: string;
  variant?: 'primary' | 'outline';
  class?: string;
}

const { href, variant = 'primary', class: className = '' } = Astro.props;

const variantClasses: Record<string, string> = {
  primary: 'bg-signal-blue-btn text-white hover:bg-signal-blue-dark',
  outline: 'border-2 border-signal-blue-dark text-signal-blue-dark hover:bg-signal-blue hover:text-white',
};
---

<a
  href={href}
  class:list={[
    'inline-block font-medium px-8 py-4 rounded-lg transition-colors focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-signal-blue',
    variantClasses[variant],
    className,
  ]}
>
  <slot />
</a>
