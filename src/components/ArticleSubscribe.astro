---
// Single standard subscribe block for newsletter pages.
// Renders at the end of article body, before share row. No dismiss button.
---

<section class="article-subscribe">
  <div class="mx-auto w-full max-w-[45rem] px-6">
    <div class="bg-ice-blue rounded-lg px-6 py-8 md:px-8 md:py-10">
      <p class="text-summit-navy font-medium text-base md:text-lg mb-4">
        Get operator-level analysis like this delivered to your inbox.
      </p>
      <form class="flex gap-3 max-w-md" id="article-subscribe-form">
        <label for="article-subscribe-email" class="sr-only">Email address</label>
        <input
          type="email"
          id="article-subscribe-email"
          name="email"
          placeholder="you@company.com"
          required
          class="flex-1 border border-summit-navy/20 rounded-lg px-4 py-3 text-sm text-summit-navy bg-white placeholder:text-summit-navy/30 focus:outline-none focus:ring-2 focus:ring-signal-blue focus:border-transparent"
        />
        <button
          type="submit"
          class="bg-signal-blue-btn text-white text-sm font-medium px-6 py-3 rounded-lg hover:bg-signal-blue-dark transition-colors flex-shrink-0"
        >
          Subscribe
        </button>
      </form>
    </div>
  </div>
</section>
